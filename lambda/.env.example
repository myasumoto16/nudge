# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# How many minutes before an event to fire the reminder
REMINDER_MINUTES_BEFORE=10

# Alexa skill ID (from ASK developer console)
SKILL_ID=amzn1.ask.skill.YOUR_SKILL_ID

# DynamoDB (Phase 4+)
DYNAMODB_TABLE_NAME=NudgeUsers
AWS_REGION=us-east-1

# Optional: async setup function that creates Google Calendar watch channels
CALENDAR_SYNC_FUNCTION_NAME=NudgeCalendarSync
