# DynamoDB
DYNAMODB_TABLE_NAME=NudgeUsers
AWS_REGION=us-east-1

# Login with Amazon — from Alexa developer console → Build → Permissions → Proactive Events
LWA_CLIENT_ID=amzn1.application-oa2-client.YOUR_ID
LWA_CLIENT_SECRET=YOUR_SECRET

# Due checker/proactive-events settings
DUE_GRACE_MINUTES=2
PROACTIVE_EVENTS_PATH=/v1/proactiveEvents/stages/development
