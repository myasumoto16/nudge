# DynamoDB
DYNAMODB_TABLE_NAME=NudgeUsers
AWS_REGION=us-east-1

# Google OAuth credentials (same as skill Lambda)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_TOKEN_ENCRYPTION_KEY_BASE64=32_byte_key_base64

# Alexa Skill Messaging credentials. Required for background update/delete of
# existing Alexa Reminders by alertToken.
LWA_CLIENT_ID=your_alexa_skill_messaging_client_id
LWA_CLIENT_SECRET=your_alexa_skill_messaging_client_secret

# Public API Gateway URL for Google Calendar watch notifications
GOOGLE_WEBHOOK_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/google/calendar/webhook

# Calendar sync settings
SYNC_LOOKAHEAD_HOURS=48
WATCH_TTL_SECONDS=604800
WATCH_RENEWAL_HOURS=24
SYNC_NUDGE_INTERVAL_HOURS=24
